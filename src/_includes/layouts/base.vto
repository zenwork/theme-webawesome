<!DOCTYPE html>
<html lang="{{ lang || metas.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title || metas.title }} - {{ metas.site }}</title>
    <meta name="color-scheme" content="light dark">
    <script>
      ;(() => {
        const lightTheme = 'wa-light'
        const darkTheme = 'wa-dark'
        const saved = window.localStorage.getItem('theme')
        const preferredDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        const next = saved === darkTheme || saved === lightTheme ? saved : preferredDark ? darkTheme : lightTheme
        document.documentElement.classList.add(next)
      })()
    </script>
    <style>
      wa-drawer:not(:defined),
      site-toc-tree:not(:defined),
      wa-tree:not(:defined),
      wa-tree-item:not(:defined) {
        display: none;
      }

      site-toc-tree:defined:not([data-ready]) {
        visibility: hidden;
      }
    </style>
    <link rel="preload" href="{{ webawesome.cssPath }}" as="style">
    <link rel="preload" href="{{ webawesome.loaderPath }}" as="script">
    <link rel="stylesheet" href="/style.css">
    <link rel="canonical" href="{{ url |> url(true) }}">
    {{# WEBAWESOME COMPONENT LIBRARY #}}
    <link rel="stylesheet" href="{{ webawesome.cssPath }}" />
    <script type="module" src="{{ webawesome.loaderPath }}" data-webawesome="{{ webawesome.assetBasePath }}"></script>
    <script
      type="module"
      src="{{ webawesome.splitPanelPath }}"
      data-webawesome="{{ webawesome.assetBasePath }}"
    ></script>
    {{# CUSTOM COMPONENTS #}}
    <script type="module" src="{{ themeComponents.primaryScript }}"></script>
  </head>
  <body>
    <wa-drawer id="site-toc-drawer" label="Documentation" placement="start">
      <section class="site-toc-shell">
        <h2>Documentation</h2>
        {{ include '../site-toc.vto' }}
      </section>
    </wa-drawer>
    <header class="site-header">
      <wa-button class="site-toc-trigger" variant="neutral" size="small" id="site-toc-trigger">Docs</wa-button>
      <a class="site-title" href="/">{{ metas.site }}</a>
      {{ include '../theme-toggle.vto' }}
    </header>
    <main class="docs-shell">
      <aside class="site-toc-panel">
        <section class="site-toc-shell">
          <h2>Documentation</h2>
          {{ include '../site-toc.vto' }}
        </section>
      </aside>
      <article class="docs-content">
        {{ content }}
      </article>
      {{ if toc?.length }}
        <aside class="page-toc-panel">
          <section class="page-toc-shell">
            <h2>On this page</h2>
            <nav aria-label="Page table of contents">
              <ol class="page-toc-list">
                {{ for item of toc }}
                  <li>
                    <a href="{{ item.url || `#${item.slug}` }}" class="toc-link">{{ item.text }}</a>
                    {{ if item.children.length }}
                      <ul class="page-toc-list">
                        {{ for child of item.children }}
                          <li>
                            <a href="{{ child.url || `#${child.slug}` }}" class="toc-link">{{ child.text }}</a>
                          </li>
                        {{ /for }}
                      </ul>
                    {{ /if }}
                  </li>
                {{ /for }}
              </ol>
            </nav>
          </section>
        </aside>
      {{ /if }}
    </main>
    <script>
      const trigger = document.getElementById('site-toc-trigger')
      const drawer = document.getElementById('site-toc-drawer')
      if (trigger && drawer) {
        trigger.addEventListener('click', () => drawer.show())
      }
    </script>
  </body>
</html>
