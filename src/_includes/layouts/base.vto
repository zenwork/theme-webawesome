<!DOCTYPE html>
<html lang="{{ lang || metas.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title || metas.title }} - {{ metas.site }}</title>
    <meta name="color-scheme" content="light dark">
    <link rel="stylesheet" href="/style.css">
    <link rel="canonical" href="{{ url |> url(true) }}">
    {{# WEBAWESOME COMPONENT LIBRARY #}}
    <link rel="stylesheet" href="/lib/webawesome/dist-cdn/styles/webawesome.css" />
    <script type="module" src="/lib/webawesome/dist-cdn/webawesome.loader.js" data-webawesome="/lib/webawesome/dist-cdn" ></script>
    <script type="module" src="/lib/webawesome/dist-cdn/components/split-panel/split-panel.js" data-webawesome="/lib/webawesome/dist-cdn" ></script>
    {{# CUSTOM COMPONENTS #}}
    <script type="module" src="/components/index.js"></script>
  </head>
  <body>
    <header>
      {{ include "../theme-toggle.vto" }}
    </header>
    <main>
      {{ content }}
    </main>
  </body>
</html>
