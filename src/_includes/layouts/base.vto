<!DOCTYPE html>
<html lang="{{ lang || metas.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title || metas.title }} - {{ metas.site }}</title>
    <meta name="color-scheme" content="light dark">
    <link rel="stylesheet" href="/style.css">
    <link rel="canonical" href="{{ url |> url(true) }}">
    {{# WEBAWESOME COMPONENT LIBRARY #}}
    <link rel="stylesheet" href="{{ webawesome.cssPath }}" />
    <script type="module" src="{{ webawesome.loaderPath }}" data-webawesome="{{ webawesome.assetBasePath }}" ></script>
    <script type="module" src="{{ webawesome.splitPanelPath }}" data-webawesome="{{ webawesome.assetBasePath }}" ></script>
    {{# CUSTOM COMPONENTS #}}
    <script type="module" src="{{ themeComponents.primaryScript }}"></script>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        <a href="/">Overview</a>
        <a href="/examples/buttons/">Buttons</a>
        <a href="/examples/forms/">Forms</a>
      </nav>
      {{ include "../theme-toggle.vto" }}
    </header>
    <main class="docs-shell">
      {{ content }}
    </main>
  </body>
</html>
