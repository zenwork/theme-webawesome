---
layout: layouts/base.vto
title: Form Control Examples
---
<section class="docs-stack">
  <header>
    <h1>{{ title }}</h1>
    <p class="lead">Runnable form snippets for common technical documentation workflows.</p>
  </header>

  <demo-pane
    data='{"label":"Email","placeholder":"you@example.com"}'
    template='<wa-input label="${label}" placeholder="${placeholder}"></wa-input>'
    imports='["input"]'
    default-tab="output">
  </demo-pane>


</section>
