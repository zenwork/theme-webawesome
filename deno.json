{
  "version": "1.0.0",
  "imports": {
    "webawesome": "./lib/webawesome/dist/",
    "lit": "npm:lit@3.3.2",
    "lit/": "npm:lit@3.3.2/",
    "lit/decorators.js": "npm:lit@3.3.2/decorators.js",
    "lit/directives/unsafe-html.js": "npm:lit@3.3.2/directives/unsafe-html.js",
    "dompurify": "npm:dompurify@^3.2.6",
    "prismjs": "npm:prismjs@^1.29.0",
    "@codemirror/state": "npm:@codemirror/state@^6.5.2",
    "@codemirror/view": "npm:@codemirror/view@^6.38.6",
    "@codemirror/commands": "npm:@codemirror/commands@^6.8.1",
    "@codemirror/language": "npm:@codemirror/language@^6.11.3",
    "@codemirror/lang-json": "npm:@codemirror/lang-json@^6.0.2",
    "@codemirror/lang-html": "npm:@codemirror/lang-html@^6.4.11",
    "@codemirror/lang-javascript": "npm:@codemirror/lang-javascript@^6.2.4",
    "@codemirror/theme-one-dark": "npm:@codemirror/theme-one-dark@^6.1.3",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.1.0/",
    "lume/cms/": "https://cdn.jsdelivr.net/gh/lumeland/cms@0.13.0/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.12/jsx-runtime.ts"
  },
  "lock": false,
  "tasks": {
    "lume": {
      "description": "Run Lume command",
      "command": "deno run -P=lume lume/cli.ts"
    },
    "build": {
      "description": "Build the site for production",
      "command": "deno task lume"
    },
    "serve": {
      "description": "Run and serve the site for development",
      "command": "deno task lume -s"
    },
    "test:browser": {
      "description": "Run browser-level smoke tests for demo pane",
      "command": "node test/browser/demo-pane-smoke.mjs"
    },
    "changelog": {
      "description": "Run the changelog utility to format the CHANGELOG.md file",
      "command": "deno run --allow-read --allow-write https://deno.land/x/changelog@v2.6.2/bin.ts"
    },
    "npm": {
      "description": "Build the npm package",
      "command": "deno run --allow-read --allow-write --allow-env tools/npm.ts"
    }
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts",
      "webawesome/dist/custom-elements-jsx.d.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume",
    "experimentalDecorators": true
  },
  "exclude": [
    "./_site"
  ],
  "unstable": [
    "temporal",
    "fmt-component"
  ],
  "permissions": {
    "lume": {
      "read": true,
      "write": [
        "./"
      ],
      "import": [
        "cdn.jsdelivr.net:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443"
      ],
      "net": [
        "0.0.0.0",
        "jsr.io:443",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "registry.npmjs.org:443"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "lint": {
    "plugins": [
      "https://cdn.jsdelivr.net/gh/lumeland/lume@3.1.0/lint.ts"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  },
  "fmt": {
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true
  },
  "nodeModulesDir": "auto"
}
